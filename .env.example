# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database Connection (MongoDB Atlas connection string)
# Example: mongodb+srv://username:password@cluster.abcde.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_connection_string_here

# Port for Keep-Alive Ping Server (Render sets this automatically)
PORT=3000

# Cryptography - 32-byte key in hex (64 hex characters) to encrypt/decrypt stored passwords
ENCRYPTION_KEY=d7a7b973ef0b8c6e2469a91176b9e25d8c6b73a7d4e58f0b7e28d4e9f7a93b4a

# Performance & Security Controls
MAX_CONCURRENT_CONNECTIONS=5
DELAY_BETWEEN_CONNECTIONS_MS=1000

# Optional proxy configuration
# PROXY_LIST_PATH=proxies.txt
